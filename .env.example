APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8010
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
RATE_LIMIT_LIVE_ARM_PER_MINUTE=5
RATE_LIMIT_BACKTEST_PER_MINUTE=30
PAPER_JOURNAL_FILE=.nexus/paper_journal.json
ENABLE_LIVE_TRADING=false
ALLOW_MAINNET_TRADING=false
LIVE_TRADING_ACKNOWLEDGEMENT=
LIVE_TRADING_APPROVAL_TOKEN=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision
BINANCE_USER_DATA_STREAM_URL=wss://stream.testnet.binance.vision/ws
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=1m
DEFAULT_EXCHANGE=binance_spot_testnet
WALLET_MODE=manual_only
METAMASK_CHAIN_ID=1
MAX_POSITION_SIZE_PCT=25
MAX_DAILY_LOSS_PCT=3
MAX_OPEN_POSITIONS=1
DEFAULT_FEE_BPS=10
DEFAULT_SLIPPAGE_BPS=5
GITHUB_REMOTE_NAME=origin
GITLAB_REMOTE_NAME=gitlab
MIRROR_EVIDENCE_PATH=ops/evidence/mirror-verification.json
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
