{$PUBLIC_HOST} {
    encode zstd gzip

    @api path /api/* /docs* /redoc* /openapi.json /metrics /health /ready
    handle @api {
        reverse_proxy api:8010
    }

    @web_config path /config.js
    handle @web_config {
        header Content-Type application/javascript
        respond "window.TTM_API_BASE_URL = window.location.origin;"
    }

    handle /ops {
        redir /ops/ 308
    }

    handle_path /ops/* {
        reverse_proxy web:8080
    }

    handle /saas {
        redir /saas/ 308
    }

    handle /saas/* {
        reverse_proxy web-next:8080
    }

    handle_path /pitch/* {
        reverse_proxy pitch:8080
    }

    handle {
        reverse_proxy pitch:8080
    }
}
