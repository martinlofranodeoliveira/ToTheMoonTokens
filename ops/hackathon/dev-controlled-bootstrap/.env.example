# Copy this to .env and fill in the values. NEVER commit .env.
CIRCLE_API_KEY=TEST_API_KEY:your_key_here

# Optional: if you already registered an Entity Secret via the Console
# (pasted a ciphertext and clicked Register), put the matching 64-char hex here
# and the script will skip registration. Otherwise leave blank and the script
# will generate + register a fresh one.
CIRCLE_ENTITY_SECRET=
